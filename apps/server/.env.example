# ============================================================
# Drama Buddy — Server Environment Variables
# Copy to .env.local and fill in your values
# ============================================================

# --- AI Provider (Chat + Vision) ---
# Options: openai | deepseek | minimax | kimi | doubao | ollama | custom
AI_PROVIDER=openai

# --- API Key ---
OPENAI_API_KEY=sk-your-key-here

# --- Base URL (optional, auto-resolved per provider) ---
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Models (optional, auto-resolved per provider) ---
AI_MODEL=gpt-4o-mini
VISION_MODEL=gpt-4o-mini

# --- ASR (Speech-to-Text) ---
# Options: openai | doubao | none
# Default: follows AI_PROVIDER (openai→openai, doubao→doubao, others→none)
# ASR_PROVIDER=openai
# ASR_API_KEY=  (defaults to OPENAI_API_KEY if not set)
WHISPER_MODEL=whisper-1

# Doubao ASR specific (火山引擎语音识别)
# DOUBAO_ASR_APP_ID=your-app-id

# --- Performance ---
AI_MAX_RETRIES=3
AI_TIMEOUT_MS=30000

# ============================================================
# Provider Quick Reference:
# ============================================================
#
# ┌────────────┬───────────────────────────────────────┬──────────────────────────────┐
# │ Provider   │ Base URL (auto)                       │ Default Model                │
# ├────────────┼───────────────────────────────────────┼──────────────────────────────┤
# │ openai     │ https://api.openai.com/v1             │ gpt-4o-mini                  │
# │ deepseek   │ https://api.deepseek.com              │ deepseek-chat                │
# │ minimax    │ https://api.minimax.chat/v1           │ MiniMax-Text-01              │
# │ kimi       │ https://api.moonshot.cn/v1            │ moonshot-v1-8k               │
# │ doubao     │ https://ark.cn-beijing.volces.com/api/v3 │ doubao-1.5-pro-32k        │
# │ ollama     │ http://localhost:11434/v1             │ llama3.1                     │
# │ custom     │ (you set OPENAI_BASE_URL)             │ gpt-4o-mini                  │
# └────────────┴───────────────────────────────────────┴──────────────────────────────┘
#
# ============================================================
# 豆包 (Doubao / 火山方舟) example:
# AI_PROVIDER=doubao
# OPENAI_API_KEY=your-ark-api-key
# AI_MODEL=doubao-1.5-pro-32k
# ASR_PROVIDER=doubao
# ASR_API_KEY=your-volc-api-key
# DOUBAO_ASR_APP_ID=your-app-id
# ============================================================
#
# ============================================================
# DeepSeek + 豆包语音 混搭 example:
# AI_PROVIDER=deepseek
# OPENAI_API_KEY=sk-your-deepseek-key
# AI_MODEL=deepseek-chat
# ASR_PROVIDER=doubao
# ASR_API_KEY=your-volc-api-key
# ============================================================
#
# ============================================================
# MiniMax example:
# AI_PROVIDER=minimax
# OPENAI_API_KEY=your-minimax-api-key
# AI_MODEL=MiniMax-Text-01
# ============================================================
#
# ============================================================
# Kimi (Moonshot) example:
# AI_PROVIDER=kimi
# OPENAI_API_KEY=sk-your-moonshot-key
# AI_MODEL=moonshot-v1-8k
# ============================================================
#
# ============================================================
# Ollama (local) example:
# AI_PROVIDER=ollama
# AI_MODEL=llama3.1
# VISION_MODEL=llava
# ============================================================
